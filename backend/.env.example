# Copy this file to backend/.env and fill in values that match your local Postgres.
# Postgres connection (SQLAlchemy URL, psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/society_portal

# Symmetric secret used to sign JWT access tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Access-token lifetime in minutes.
JWT_EXPIRY_MINUTES=720

# Comma-separated list of origins allowed to call the API.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seed officer credentials (created/updated by `python -m app.seed`).
# After first run these passwords MUST be changed via the API; the seed
# script never overwrites existing hashes for officer accounts.
SEED_TREASURER_EMAIL=treasurer@cardmasterenclave.in
SEED_TREASURER_PASSWORD=ChangeMe!Treasurer1
SEED_TREASURER_NAME=Society Treasurer

SEED_PRESIDENT_EMAIL=president@cardmasterenclave.in
SEED_PRESIDENT_PASSWORD=ChangeMe!President1
SEED_PRESIDENT_NAME=Society President

SEED_SECRETARY_EMAIL=secretary@cardmasterenclave.in
SEED_SECRETARY_PASSWORD=ChangeMe!Secretary1
SEED_SECRETARY_NAME=Society Secretary

# Default annual maintenance amount in rupees (matches the supplied FY ledger).
DEFAULT_ANNUAL_MAINTENANCE=88000
